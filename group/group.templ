package group

import "github.com/fastygo/base/utils"

templ Group(props GroupProps) {
	switch utils.ResolveTag(props.Tag, "div", utils.TagGroupGroup) {
		case "section":
			<section class={ props.Class } { groupSpreadAttrs(props)... }>{ children... }</section>
		case "article":
			<article class={ props.Class } { groupSpreadAttrs(props)... }>{ children... }</article>
		case "aside":
			<aside class={ props.Class } { groupSpreadAttrs(props)... }>{ children... }</aside>
		case "header":
			<header class={ props.Class } { groupSpreadAttrs(props)... }>{ children... }</header>
		case "footer":
			<footer class={ props.Class } { groupSpreadAttrs(props)... }>{ children... }</footer>
		case "main":
			<main class={ props.Class } { groupSpreadAttrs(props)... }>{ children... }</main>
		case "nav":
			<nav class={ props.Class } { groupSpreadAttrs(props)... }>{ children... }</nav>
		case "figure":
			<figure class={ props.Class } { groupSpreadAttrs(props)... }>{ children... }</figure>
		case "fieldset":
			<fieldset class={ props.Class } { groupSpreadAttrs(props)... }>{ children... }</fieldset>
		default:
			<div class={ props.Class } { groupSpreadAttrs(props)... }>{ children... }</div>
	}
}
