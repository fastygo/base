package button

import "strings"

templ Button(props ButtonProps, label string) {
	@ButtonBlock(props) {
		{ label }
	}
}

templ ButtonBlock(props ButtonProps) {
	if strings.TrimSpace(props.Href) != "" {
		if props.Disabled {
			<a
				href={ templ.SafeURL(props.Href) }
				class={ props.Class }
				rel="nofollow noopener noreferrer"
				{ buttonAttrs(props)... }
			>{ children... }</a>
		} else {
			<a href={ templ.SafeURL(props.Href) } class={ props.Class } { buttonAttrs(props)... }>{ children... }</a>
		}
	} else {
		<button type={ buttonType(props.Type) } class={ props.Class } disabled?={ props.Disabled } { buttonAttrs(props)... }>{ children... }</button>
	}
}
