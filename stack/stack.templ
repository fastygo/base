package stack

import "github.com/fastygo/base/utils"

templ Stack(props StackProps) {
	switch utils.ResolveTag(props.Tag, "div", utils.TagGroupStack) {
		case "section":
			<section class={ props.Class } { stackSpreadAttrs(props)... }>{ children... }</section>
		case "article":
			<article class={ props.Class } { stackSpreadAttrs(props)... }>{ children... }</article>
		case "aside":
			<aside class={ props.Class } { stackSpreadAttrs(props)... }>{ children... }</aside>
		case "header":
			<header class={ props.Class } { stackSpreadAttrs(props)... }>{ children... }</header>
		case "footer":
			<footer class={ props.Class } { stackSpreadAttrs(props)... }>{ children... }</footer>
		case "main":
			<main class={ props.Class } { stackSpreadAttrs(props)... }>{ children... }</main>
		case "nav":
			<nav class={ props.Class } { stackSpreadAttrs(props)... }>{ children... }</nav>
		case "figure":
			<figure class={ props.Class } { stackSpreadAttrs(props)... }>{ children... }</figure>
		case "ul":
			<ul class={ props.Class } { stackSpreadAttrs(props)... }>{ children... }</ul>
		case "ol":
			<ol class={ props.Class } { stackSpreadAttrs(props)... }>{ children... }</ol>
		default:
			<div class={ props.Class } { stackSpreadAttrs(props)... }>{ children... }</div>
	}
}
